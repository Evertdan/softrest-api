# SoftRest API — Variables de entorno para desarrollo local
# ============================================================
# Configuración del backend API (Node.js + Fastify + Drizzle ORM)
# ============================================================

# ----------------------------------------------------------
# Aplicación
# ----------------------------------------------------------
NODE_ENV=development
PORT=4000
APP_HOST=0.0.0.0
API_URL=http://localhost:4000
WEB_URL=http://localhost:5173

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# ----------------------------------------------------------
# Base de datos (MariaDB 10.11)
# ----------------------------------------------------------
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=softrest
DB_USER=softrest_dev
DB_PASSWORD=devpassword
DB_ROOT_PASSWORD=devroot
DB_URL=mysql://softrest_dev:devpassword@localhost:3306/softrest

# ----------------------------------------------------------
# Redis (requerido — cache, rate-limit, cola de jobs)
# ----------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------
# MinIO (S3-compatible local)
# ----------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=softrest
MINIO_USE_SSL=false
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=softrest-uploads
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ----------------------------------------------------------
# Correo (opcional — para pruebas locales usar Mailpit o similar)
# ----------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@softrest.local

# ----------------------------------------------------------
# Socket.IO / Realtime
# ----------------------------------------------------------
SOCKET_CORS_ORIGIN=http://localhost:5173,http://localhost:19006

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
LOG_LEVEL=debug
LOG_PRETTY=true

# ----------------------------------------------------------
# Feature flags (JSON inline para desarrollo)
# ----------------------------------------------------------
FEATURE_FLAGS='{"kds.recall.enabled":true,"cfdi.enabled":false,"delivery.uberEats.enabled":false,"loyalty.enabled":false,"stock.enforcement":"WARN"}'

# ----------------------------------------------------------
# Integraciones externas (placeholders para desarrollo)
# ----------------------------------------------------------
# SENTRY_DSN=
# PAC_FACTURAMA_API_KEY=
# UBER_EATS_CLIENT_ID=
# UBER_EATS_CLIENT_SECRET=
# RAPPI_CLIENT_ID=
# DIDI_CLIENT_ID=