# SoftRest API - Variables de Entorno

# ============================================
# APLICACIÓN
# ============================================
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000

# ============================================
# BASE DE DATOS (MariaDB)
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=softrest
DB_USER=softrest_dev
DB_PASSWORD=devpassword
DB_ROOT_PASSWORD=devroot
DB_URL=mysql://softrest_dev:devpassword@localhost:3306/softrest

# ============================================
# REDIS
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ============================================
# AUTENTICACIÓN JWT
# ============================================
JWT_SECRET=dev-jwt-secret-cambiar-en-produccion-minimo-32-caracteres
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# SEGURIDAD
# ============================================
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000,http://localhost:19006

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_PRETTY=true

# ============================================
# ALMACENAMIENTO DE ARCHIVOS (MinIO/S3)
# ============================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=softrest-uploads
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_KDS_RECALL=true
FEATURE_CFDI=false
FEATURE_DELIVERY_UBER=false
FEATURE_DELIVERY_RAPPI=false
FEATURE_DELIVERY_DIDI=false
FEATURE_LOYALTY=false
FEATURE_MULTI_TENANT=true

# ============================================
# CORREO (SMTP)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@softrest.io

# ============================================
# MONITOREO (opcional)
# ============================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development