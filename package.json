{
  "name": "softrest-api",
  "version": "2.0.0",
  "description": "SoftRest v2 - API Backend para Sistema POS de Restaurantes",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@fastify/websocket": "^11.0.0",
    "drizzle-orm": "^0.36.0",
    "mysql2": "^3.11.0",
    "jose": "^5.9.0",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.0",
    "dotenv": "^16.4.0",
    "ioredis": "^5.4.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "dayjs": "^1.11.0",
    "uuid": "^10.0.0",
    "sharp": "^0.33.0",
    "qrcode": "^1.5.0",
    "uuidv7": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^10.0.0",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^^8.0.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}